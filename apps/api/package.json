{
  "name": "@rr/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/infrastructure/migrate.ts",
    "seed": "tsx src/infrastructure/seed.ts",
    "privacy": "tsx src/privacy/cli.ts",
    "lint": "eslint src",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "test:regression": "vitest run -t regression"
  },
  "dependencies": {
    "@azure/identity": "^4.4.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/instrumentation-express": "^0.68.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/instrumentation-pg": "^0.72.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@rr/crypto": "*",
    "@rr/frameworks-data": "*",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "forwarded-parse": "^2.1.2",
    "helmet": "^8.3.0",
    "jose": "^6.2.3",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
