# ---- Copy to .env and fill in. NEVER commit .env ----

# Postgres
POSTGRES_USER=rr_app
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=risk_register
DATABASE_URL=postgres://rr_app:change_me_locally@db:5432/risk_register
# Set to "true" only when the database endpoint terminates TLS (managed
# Postgres / a TLS-enabled instance). Leave empty/false for the local
# docker-compose db, which does not serve TLS.
DATABASE_SSL=false

# API
API_PORT=8080
NODE_ENV=development
CORS_ORIGIN=https://localhost

# Microsoft Entra ID (OIDC / SSO)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_CLIENT_ID=api-app-registration-client-id
ENTRA_API_AUDIENCE=api://risk-register
# JWKS + issuer are derived from the tenant id at runtime.

# Microsoft Graph (email notifications — application permission Mail.Send)
GRAPH_CLIENT_ID=worker-app-registration-client-id
GRAPH_CLIENT_SECRET=set-in-key-vault-not-here
GRAPH_SENDER_UPN=grc-notifications@yourtenant.onmicrosoft.com

# Web SPA (Vite — only public values; injected at build)
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_SPA_CLIENT_ID=spa-app-registration-client-id
VITE_API_SCOPE=api://risk-register/access_as_user
VITE_API_BASE=/api
