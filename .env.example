# ---- Copy to .env and fill in. NEVER commit .env ----

# Postgres
POSTGRES_USER=rr_app
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=risk_register
DATABASE_URL=postgres://rr_app:change_me_locally@db:5432/risk_register
# Set to "true" only when the database endpoint terminates TLS (managed
# Postgres / a TLS-enabled instance). Leave empty/false for the local
# docker-compose db, which does not serve TLS.
DATABASE_SSL=false

# API
API_PORT=8080
NODE_ENV=development
CORS_ORIGIN=https://localhost
# Personnel module (team SWOT + development plans) — sensitive PII, gated OFF
# by default until DPIA sign-off. Set true to mount /personnel (and set the
# matching VITE_PERSONNEL_MODULE_ENABLED for the SPA).
PERSONNEL_MODULE_ENABLED=false

# Encryption at rest — OPT-IN, pluggable (see docs/security/encryption-at-rest.md).
# Read by BOTH the API and the worker (the worker decrypts recipient addresses).
# Pick ONE provider. Unset = disabled (fields stored in clear; warned in prod).
#  A) OpenBao / Vault Transit (key never leaves the KMS):
# BAO_ADDR=http://openbao:8200
# BAO_TOKEN=dev-root
# BAO_TRANSIT_KEY=risk-register
#  B) Local key (AES-256-GCM; 32 bytes, base64) — inject via a secret, never commit:
# DATA_ENCRYPTION_KEY=base64-32-bytes
# DATA_INDEX_KEY=base64-32-bytes   # blind-index key for encrypted-column lookups

# Distributed tracing (OpenTelemetry) — OPT-IN. Leave unset to disable (no-op).
# Point at any OTLP/HTTP collector (Tempo, Jaeger, a SaaS) to enable API + worker
# traces (HTTP / Express / pg auto-instrumented).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=rr-api

# Microsoft Entra ID (OIDC / SSO)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_CLIENT_ID=api-app-registration-client-id
ENTRA_API_AUDIENCE=api://risk-register
# JWKS + issuer are derived from the tenant id at runtime.

# Microsoft Graph (email notifications — application permission Mail.Send)
GRAPH_CLIENT_ID=worker-app-registration-client-id
GRAPH_CLIENT_SECRET=set-in-key-vault-not-here
GRAPH_SENDER_UPN=grc-notifications@yourtenant.onmicrosoft.com

# Web SPA (Vite — only public values; injected at build)
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_SPA_CLIENT_ID=spa-app-registration-client-id
VITE_API_SCOPE=api://risk-register/access_as_user
VITE_API_BASE=/api
# Surface the personnel module (Teams/SWOT/development plans) in the SPA. Must
# match the API's PERSONNEL_MODULE_ENABLED. DPIA-gated — leave false until sign-off.
VITE_PERSONNEL_MODULE_ENABLED=false
